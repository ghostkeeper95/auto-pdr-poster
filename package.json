{
  "name": "auto-pdr-poster",
  "version": "1.0.0",
  "description": "Automated tool to scrape PDR quizzes from pdrtest.com and post them to Telegram",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/bot.js",
    "dev": "tsx src/bot.ts",
    "post": "QUESTIONS_PER_RUN=1 tsx src/index.ts",
    "post:5": "QUESTIONS_PER_RUN=5 tsx src/index.ts",
    "bot": "tsx src/bot.ts"
  },
  "keywords": [
    "pdr",
    "telegram",
    "quiz",
    "automation"
  ],
  "license": "MIT",
  "dependencies": {
    "@grammyjs/conversations": "^2.1.1",
    "@grammyjs/menu": "^1.3.1",
    "cheerio": "^1.2.0",
    "chrono-node": "^2.9.0",
    "dotenv": "^16.4.7",
    "grammy": "^1.42.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/node": "^20.17.12",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
